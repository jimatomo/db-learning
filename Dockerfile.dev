# 開発用: ソースは bind mount、node_modules は名前付きボリューム推奨
FROM oven/bun:1
WORKDIR /app

ARG DUCKDB_VERSION=1.3.0
ENV HOME=/root

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# DuckDB CLI + sqlite 拡張（INSIGHTS_ENGINE=duckdb_cli / insights_duckdb.sql 用）
# ビルド時に INSTALL しておくと、実行時の初回ダウンロードやオフラインに強くなります
RUN ARCH=$(uname -m) \
    && case "$ARCH" in \
         aarch64) DUCK_ARCH=arm64 ;; \
         x86_64) DUCK_ARCH=amd64 ;; \
         *) echo "unsupported arch: $ARCH" && exit 1 ;; \
       esac \
    && curl -fsSL "https://github.com/duckdb/duckdb/releases/download/v${DUCKDB_VERSION}/duckdb_cli-linux-${DUCK_ARCH}.zip" -o /tmp/duckdb.zip \
    && unzip -o /tmp/duckdb.zip -d /usr/local/bin \
    && chmod +x /usr/local/bin/duckdb \
    && rm /tmp/duckdb.zip \
    && duckdb :memory: "INSTALL sqlite;" \
    && duckdb :memory: "LOAD sqlite;"

COPY package.json bun.lock ./
COPY apps/server/package.json apps/server/package.json
COPY apps/web/package.json apps/web/package.json
COPY packages/db/package.json packages/db/package.json
RUN bun install

COPY docker/dev-entrypoint.sh /usr/local/bin/dev-entrypoint.sh
RUN chmod +x /usr/local/bin/dev-entrypoint.sh

EXPOSE 3000 5173
ENTRYPOINT ["/usr/local/bin/dev-entrypoint.sh"]
